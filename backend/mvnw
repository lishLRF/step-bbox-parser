#!/bin/sh
# ----------------------------------------------------------------------------
# Maven Start Up Batch script
#
# This is a trimmed wrapper. In production replace with the official one from
# https://maven.apache.org/wrapper/
# ----------------------------------------------------------------------------
set -e
[ -n "$MAVEN_HOME" ] && exec "$MAVEN_HOME/bin/mvn" "$@"
if command -v mvn >/dev/null 2>&1; then exec mvn "$@"; fi
echo "Maven not found. Install Maven or set MAVEN_HOME." >&2
exit 127
